# OpenAI API Key for recipe extraction (server-side)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: API base URL for calling deployed endpoints during local dev
# Example: https://recipe-vault.vercel.app (leave blank to use same origin)
VITE_API_BASE_URL=

# Optional: Restrict which origins can call the serverless API
# Comma-separated list, supports * wildcards
# Example: https://recipe-vault.vercel.app,https://recipe-vault-*.vercel.app
CORS_ALLOW_ORIGIN=

# Firebase Configuration
# Get these from: https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
