# ============================================================
#  GATHERER APP — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git — it is listed in .gitignore.
# ============================================================

# Firebase Configuration
# Get these from: https://console.firebase.google.com/ → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# OpenAI API Key (server-side only, never expose to client)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: API base URL for calling deployed endpoints during local dev
VITE_API_BASE_URL=

# Optional: Restrict which origins can call the serverless API
CORS_ALLOW_ORIGIN=
